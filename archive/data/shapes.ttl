@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix gtfs: <http://vocab.gtfs.org/terms#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<#StopShape>
    a sh:NodeShape ;
    sh:targetClass gtfs:Stop ;
    sh:property [
        sh:path gtfs:name ;
        sh:minCount 1 ;
        sh:datatype xsd:string ;
    ] .
